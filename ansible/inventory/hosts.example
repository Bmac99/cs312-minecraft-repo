# ── Inventory ─────────────────────────────────────────────────────────────────
# Replace <MINECRAFT_PUBLIC_IP> with the value from:
#   terraform output minecraft_public_ip

[minecraft]
minecraft-server ansible_host=<MINECRAFT_PUBLIC_IP> ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/your-key.pem

[minecraft:vars]
ansible_python_interpreter=/usr/bin/python3
